# Copy to .env and fill in. Never commit the real .env file.

# Used by src/alerts.py to publish breach notifications.
# Get this from terraform output sns_topic_arn after `terraform apply`.
SNS_TOPIC_ARN=

# AWS credentials (prefer an IAM role / OIDC over static keys where possible)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
