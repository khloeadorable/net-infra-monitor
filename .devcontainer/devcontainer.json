{
  "name": "Python 3",
  "image": "mcr.microsoft.com/devcontainers/python:1-3.12-bookworm",
  "customizations": {
    "codespaces": {
      "openFiles": ["README.md", "src/app.py"]
    },
    "vscode": {
      "settings": {},
      "extensions": ["ms-python.python", "ms-python.vscode-pylance", "charliermarsh.ruff"]
    }
  },
  "updateContentCommand": "pip3 install --user -r requirements-dev.txt && echo '✅ Packages installed'",
  "postAttachCommand": {
    "server": "streamlit run src/app.py --server.enableCORS false --server.enableXsrfProtection false"
  },
  "portsAttributes": {
    "8501": {
      "label": "Application",
      "onAutoForward": "openPreview"
    }
  },
  "forwardPorts": [8501]
}
